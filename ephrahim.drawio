<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.3.0 Chrome/140.0.7339.249 Electron/38.7.2 Safari/537.36" version="29.3.0">
  <diagram name="Page-1" id="NCayY-7fiEI46s-BS8at">
    <mxGraphModel dx="1245" dy="916" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nabstract class User {\n  userId : String\n  name : String\n  email : String\n  password : String\n  role : String\n  login()\n  logout()\n  register()\n}\n\nclass RegisteredUser {\n  favorites : List&lt;Business&gt;\n  addReview()\n  rateBusiness()\n  saveBusiness()\n}\n\nclass BusinessOwner {\n  createBusiness()\n  updateBusiness()\n  deleteBusiness()\n  respondToReview()\n}\n\nclass Administrator {\n  manageUsers()\n  manageBusinesses()\n  manageCategories()\n  moderateReviews()\n}\n\nclass Business {\n  businessId : String\n  name : String\n  description : String\n  phone : String\n  email : String\n  address : String\n  latitude : Float\n  longitude : Float\n  avgRating : Float\n  addBusiness()\n  updateBusiness()\n  deleteBusiness()\n  calculateRating()\n}\n\nclass Review {\n  reviewId : String\n  rating : Integer\n  comment : String\n  date : Date\n  ownerReply : String\n  addReview()\n  editReview()\n  deleteReview()\n}\n\nclass Category {\n  categoryId : String\n  name : String\n  description : String\n  addCategory()\n  updateCategory()\n  deleteCategory()\n}\n\nUser &lt;|-- RegisteredUser\nUser &lt;|-- BusinessOwner\nUser &lt;|-- Administrator\n\nBusinessOwner \&quot;1\&quot; -- \&quot;0..*\&quot; Business : owns\nCategory \&quot;1\&quot; -- \&quot;0..*\&quot; Business : categorizes\nBusiness \&quot;1\&quot; -- \&quot;0..*\&quot; Review : has\nRegisteredUser \&quot;1\&quot; -- \&quot;0..*\&quot; Review : writes\nRegisteredUser \&quot;0..*\&quot; -- \&quot;0..*\&quot; Business : favorites\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="dl9WDsdxr9mXttLuDLJ_-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;imageBackground=none;imageBorder=default;" vertex="1">
            <mxGeometry height="941" width="735" x="882" y="-177" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml CameroonZoom_Directory\n\nskinparam classAttributeIconSize 0\nskinparam classFontSize 12\nskinparam classBackgroundColor #FAFAFA\nskinparam classBorderColor #888888\nskinparam ArrowColor #444444\nskinparam classFontName Arial\n\n&#39; ─────────────────────────────────────────\n&#39; ABSTRACT BASE\n&#39; ─────────────────────────────────────────\n\nabstract class User {\n  - userId : String\n  - name : String\n  - email : String\n  - passwordHash : String\n  - phone : String\n  - avatarUrl : String\n  - createdAt : DateTime\n  - isActive : Boolean\n  --\n  + register() : void\n  + login() : AuthToken\n  + logout() : void\n  + updateProfile() : void\n  + deactivate() : void\n}\n\n&#39; ─────────────────────────────────────────\n&#39; CONCRETE USER ROLES\n&#39; ─────────────────────────────────────────\n\nclass Visitor {\n  - sessionToken : String\n  - ipAddress : String\n  --\n  + browse() : List&lt;Business&gt;\n  + searchBusinesses() : List&lt;Business&gt;\n  + viewProfile() : Business\n}\n\nclass RegisteredUser {\n  - savedBusinesses : List&lt;String&gt;\n  --\n  + saveBookmark() : void\n  + removeBookmark() : void\n  + submitReview() : Review\n  + editReview() : void\n  + deleteReview() : void\n  + getSavedBusinesses() : List&lt;Business&gt;\n}\n\nclass BusinessOwner {\n  - verificationStatus : VerificationStatus\n  - verifiedAt : DateTime\n  --\n  + createListing() : Business\n  + updateListing() : void\n  + deleteListing() : void\n  + respondToReview() : ReviewResponse\n  + getMyBusinesses() : List&lt;Business&gt;\n  + claimBusiness() : void\n}\n\nclass Administrator {\n  - adminLevel : Int\n  --\n  + approveBusinessListing() : void\n  + rejectBusinessListing() : void\n  + suspendUser() : void\n  + deleteUser() : void\n  + manageCategory() : void\n  + viewAuditLog() : List&lt;AuditLog&gt;\n  + generateReport() : Report\n}\n\n&#39; ─────────────────────────────────────────\n&#39; AUTHENTICATION\n&#39; ─────────────────────────────────────────\n\nclass AuthToken {\n  - tokenId : String\n  - token : String\n  - expiresAt : DateTime\n  - isRevoked : Boolean\n  --\n  + validate() : Boolean\n  + revoke() : void\n  + refresh() : AuthToken\n}\n\n&#39; ─────────────────────────────────────────\n&#39; BUSINESS &amp; RELATED\n&#39; ─────────────────────────────────────────\n\nclass Business {\n  - businessId : String\n  - name : String\n  - description : String\n  - website : String\n  - email : String\n  - phone : String\n  - status : BusinessStatus\n  - averageRating : Float\n  - totalReviews : Int\n  - createdAt : DateTime\n  - updatedAt : DateTime\n  --\n  + getProfile() : Business\n  + updateDetails() : void\n  + publish() : void\n  + suspend() : void\n  + calculateAverageRating() : Float\n  + getReviews() : List&lt;Review&gt;\n  + getGallery() : List&lt;MediaAsset&gt;\n}\n\nclass Location {\n  - locationId : String\n  - address : String\n  - city : String\n  - region : String\n  - country : String\n  - postalCode : String\n  - latitude : Double\n  - longitude : Double\n  --\n  + getCoordinates() : Coordinate\n  + formatAddress() : String\n  + distanceTo() : Double\n}\n\nclass ContactInfo {\n  - contactId : String\n  - primaryPhone : String\n  - secondaryPhone : String\n  - email : String\n  - whatsapp : String\n  - facebook : String\n  - twitter : String\n  - instagram : String\n  --\n  + getPrimaryContact() : String\n  + getSocialLinks() : Map\n}\n\nclass BusinessHours {\n  - hoursId : String\n  - dayOfWeek : DayOfWeek\n  - openTime : Time\n  - closeTime : Time\n  - isClosed : Boolean\n  --\n  + isOpenNow() : Boolean\n  + getSchedule() : String\n}\n\nclass MediaAsset {\n  - assetId : String\n  - url : String\n  - type : MediaType\n  - altText : String\n  - uploadedAt : DateTime\n  - isPrimary : Boolean\n  --\n  + upload() : void\n  + delete() : void\n  + setAsPrimary() : void\n}\n\n&#39; ─────────────────────────────────────────\n&#39; CATEGORY\n&#39; ─────────────────────────────────────────\n\nclass Category {\n  - categoryId : String\n  - name : String\n  - slug : String\n  - description : String\n  - iconUrl : String\n  - parentId : String\n  - isActive : Boolean\n  --\n  + getSubcategories() : List&lt;Category&gt;\n  + getBusinesses() : List&lt;Business&gt;\n  + activate() : void\n  + deactivate() : void\n}\n\n&#39; ─────────────────────────────────────────\n&#39; REVIEW &amp; RESPONSE\n&#39; ─────────────────────────────────────────\n\nclass Review {\n  - reviewId : String\n  - rating : Int\n  - title : String\n  - body : String\n  - visitDate : Date\n  - isVerified : Boolean\n  - status : ReviewStatus\n  - createdAt : DateTime\n  - updatedAt : DateTime\n  --\n  + submit() : void\n  + edit() : void\n  + delete() : void\n  + flag() : void\n  + approve() : void\n}\n\nclass ReviewResponse {\n  - responseId : String\n  - body : String\n  - createdAt : DateTime\n  - updatedAt : DateTime\n  --\n  + post() : void\n  + edit() : void\n  + delete() : void\n}\n\n&#39; ─────────────────────────────────────────\n&#39; SEARCH &amp; FILTER\n&#39; ─────────────────────────────────────────\n\nclass SearchQuery {\n  - queryId : String\n  - keyword : String\n  - categoryId : String\n  - city : String\n  - minRating : Float\n  - radius : Double\n  - sortBy : SortField\n  - page : Int\n  - pageSize : Int\n  --\n  + execute() : SearchResult\n  + applyFilters() : void\n  + paginate() : SearchResult\n}\n\nclass SearchResult {\n  - resultId : String\n  - totalCount : Int\n  - currentPage : Int\n  - results : List&lt;Business&gt;\n  - executionTimeMs : Int\n  --\n  + getResults() : List&lt;Business&gt;\n  + hasNextPage() : Boolean\n  + getSummary() : String\n}\n\n&#39; ─────────────────────────────────────────\n&#39; BOOKMARK\n&#39; ─────────────────────────────────────────\n\nclass Bookmark {\n  - bookmarkId : String\n  - savedAt : DateTime\n  - note : String\n  --\n  + save() : void\n  + remove() : void\n}\n\n&#39; ─────────────────────────────────────────\n&#39; REPORT &amp; AUDIT\n&#39; ─────────────────────────────────────────\n\nclass Report {\n  - reportId : String\n  - type : ReportType\n  - generatedAt : DateTime\n  - parameters : Map\n  - filePath : String\n  --\n  + generate() : void\n  + export() : File\n  + schedule() : void\n}\n\nclass AuditLog {\n  - logId : String\n  - action : String\n  - targetEntity : String\n  - targetId : String\n  - performedAt : DateTime\n  - ipAddress : String\n  --\n  + record() : void\n  + getDetails() : String\n}\n\n&#39; ─────────────────────────────────────────\n&#39; ENUMERATIONS\n&#39; ─────────────────────────────────────────\n\nenum BusinessStatus {\n  PENDING\n  ACTIVE\n  SUSPENDED\n  REJECTED\n}\n\nenum ReviewStatus {\n  PENDING\n  APPROVED\n  FLAGGED\n  REMOVED\n}\n\nenum VerificationStatus {\n  UNVERIFIED\n  PENDING\n  VERIFIED\n}\n\nenum MediaType {\n  IMAGE\n  VIDEO\n  DOCUMENT\n}\n\nenum ReportType {\n  USER_ACTIVITY\n  BUSINESS_LISTINGS\n  REVIEW_SUMMARY\n  AUDIT_TRAIL\n}\n\n&#39; ─────────────────────────────────────────\n&#39; INHERITANCE\n&#39; ─────────────────────────────────────────\n\nUser &lt;|-- Visitor\nUser &lt;|-- RegisteredUser\nRegisteredUser &lt;|-- BusinessOwner\nRegisteredUser &lt;|-- Administrator\n\n&#39; ─────────────────────────────────────────\n&#39; ASSOCIATIONS\n&#39; ─────────────────────────────────────────\n\nUser \&quot;1\&quot; --&gt; \&quot;0..*\&quot; AuthToken           : authenticates via\n\nBusinessOwner \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Business   : owns\nBusiness \&quot;1\&quot; *-- \&quot;1\&quot;    Location        : located at\nBusiness \&quot;1\&quot; *-- \&quot;1\&quot;    ContactInfo     : reachable via\nBusiness \&quot;1\&quot; *-- \&quot;0..*\&quot; BusinessHours   : operates during\nBusiness \&quot;1\&quot; *-- \&quot;0..*\&quot; MediaAsset      : displayed through\nBusiness \&quot;0..*\&quot; --&gt; \&quot;1..*\&quot; Category     : classified under\n\nRegisteredUser \&quot;1\&quot;  --&gt; \&quot;0..*\&quot; Review    : writes\nReview \&quot;1\&quot; *-- \&quot;0..1\&quot; ReviewResponse    : replied to by\nBusinessOwner \&quot;1\&quot; --&gt; \&quot;0..*\&quot; ReviewResponse : posts\n\nRegisteredUser \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Bookmark   : saves\nBookmark \&quot;0..*\&quot; --&gt; \&quot;1\&quot; Business         : references\n\nSearchQuery \&quot;0..*\&quot; --&gt; \&quot;0..*\&quot; Business   : retrieves\nSearchQuery \&quot;1\&quot;    --&gt; \&quot;1\&quot;    SearchResult : produces\n\nCategory \&quot;0..1\&quot; --&gt; \&quot;0..*\&quot; Category      : parent of\n\nAdministrator \&quot;1\&quot; --&gt; \&quot;0..*\&quot; AuditLog    : reviews\nAdministrator \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Report      : generates\nAdministrator \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Category    : manages\n\nBusiness \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Review           : receives\n\n&#39; ─────────────────────────────────────────\n&#39; STATUS USAGE\n&#39; ─────────────────────────────────────────\n\nBusiness ..&gt; BusinessStatus\nReview   ..&gt; ReviewStatus\nBusinessOwner ..&gt; VerificationStatus\nMediaAsset ..&gt; MediaType\nReport ..&gt; ReportType\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="dl9WDsdxr9mXttLuDLJ_-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1741" width="2033" x="360" y="1000" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
